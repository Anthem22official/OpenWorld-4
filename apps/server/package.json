{
  "name": "openworld-server",
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "prisma:generate": "prisma generate",
    "prisma:generate:hosted": "prisma generate --schema prisma/schema.hosted.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.hosted.prisma",
    "prisma:push": "prisma db push",
    "prisma:push:hosted": "prisma db push --schema prisma/schema.hosted.prisma",
    "prisma:seed:production": "tsx prisma/seed-production.ts",
    "prisma:seed:hosted": "tsx prisma/import-hosted-seed.ts",
    "seed:export:local": "prisma generate && tsx prisma/export-local-seed.ts",
    "schema:check": "node ../../scripts/check-prisma-schema-sync.mjs",
    "start:hosted": "tsx src/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@types/express": "^5.0.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prisma": "^5.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
